{
  "name": "bookshelf-api",
  "version": "1.0.0",
  "description": "書籍と著者を管理するバックエンド API です。",
  "scripts": {
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "secrets:scan": "gitleaks detect --source . --no-git --redact --verbose",
    "secrets:protect": "gitleaks protect --staged --redact --verbose"
  },
  "type": "commonjs",
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "husky": "^9.1.7"
  },
  "private": true
}
